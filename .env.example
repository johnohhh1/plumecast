# PlumeCast™ Environment Variables
# Copy this file to .env.local and fill in your keys.

# 1. Mapbox Public Token (Required for 3D Map)
# Get one: https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN=

# 2. Google Gemini API Key (Required for AI Commander)
# Get one: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# 3. OpenWeatherMap API Key (Required for live weather)
# Get one: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=
